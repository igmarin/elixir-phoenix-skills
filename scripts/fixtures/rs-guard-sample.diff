@@ -0,0 +1,29 @@
+<div class="product-index">
+  <h1>Products</h1>
+
+  <.search_form />
+
+  <div id="products" phx-update="stream">
+    <div :for={{id, product} <- @streams.products} id={id}>
+      <div class="product-card">
+        <h2><%= product.name %></h2>
+        <p><%= product.description %></p>
+        <span class="price"><%= product.price %></span>
+      </div>
+    </div>
+  </div>
+</div>
+
+<.search_form :let={f}>
+  <.form for={f} phx-change="search" phx-debounce="300">
+    <.input
+      field={f[:term]}
+      type="text"
+      placeholder="Search products..."
+      autocomplete="off"
+    />
+  </.form>
+</.search_form>
diff --git a/lib/my_app/catalog.ex b/lib/my_app/catalog.ex
index b12e456..c9d8901 100644
--- a/lib/my_app/catalog.ex
+++ b/lib/my_app/catalog.ex
@@ -5,6 +5,21 @@ defmodule MyApp.Catalog do
     Repo.all(Product)
   end

+  @doc """
+  Returns a list of products matching the search term.
+  """
+  def search_products(term) do
+    search_term = "%#{term}%"
+
+    from(p in Product,
+      where: ilike(p.name, ^search_term) or ilike(p.description, ^search_term),
+      order_by: [asc: p.name]
+    )
+    |> Repo.all()
+  end
+
   def get_product!(id), do: Repo.get!(Product, id)

